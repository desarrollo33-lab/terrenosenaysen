// Gallery lightbox functionality
let galleryIdx=0;function galleryNav(d){document.querySelectorAll(".property-gallery").forEach(g=>{const imgs=JSON.parse(g.dataset.images??"[]"),alts=JSON.parse(g.dataset.alts??"[]");if(!imgs.length)return;galleryIdx=(galleryIdx+d%imgs.length+imgs.length)%imgs.length;const lbImg=g.querySelector(".gallery-lightbox-img"),counter=g.querySelector(".gallery-counter"),mainImg=g.querySelector(".gallery-main-img");lbImg.style.opacity="0";const tmp=new Image;tmp.onload=()=>{lbImg.src=imgs[galleryIdx];lbImg.alt=alts[galleryIdx]||"";lbImg.style.opacity="1"};tmp.onerror=()=>{lbImg.src=imgs[galleryIdx];lbImg.style.opacity="0.5"};tmp.src=imgs[galleryIdx];if(counter)counter.textContent=galleryIdx+1+" / "+imgs.length;g.querySelectorAll(".gallery-lb-dot").forEach((dot,i)=>{dot.classList.toggle("bg-white",i===galleryIdx);dot.classList.toggle("scale-125",i===galleryIdx);dot.classList.toggle("bg-white/40",i!==galleryIdx)});if(mainImg)mainImg.src=imgs[galleryIdx]})}
document.addEventListener("DOMContentLoaded",()=>{document.querySelectorAll(".property-gallery").forEach(g=>{const imgs=JSON.parse(g.dataset.images??"[]"),alts=JSON.parse(g.dataset.alts??"[]");if(!imgs.length)return;const lbImg=g.querySelector(".gallery-lightbox-img"),counter=g.querySelector(".gallery-counter"),dots=g.querySelector(".gallery-lb-dots"),lb=g.querySelector(".gallery-lightbox");if(imgs[0]&&lbImg){lbImg.src=imgs[0];lbImg.alt=alts[0]||""}if(counter)counter.textContent="1 / "+imgs.length;if(dots)imgs.forEach((_,i)=>{const dot=document.createElement("button");dot.className="gallery-lb-dot size-2 rounded-full bg-white/40 transition";dot.dataset.index=i;dot.addEventListener("click",()=>{galleryIdx=i;galleryNav(0)});dots.appendChild(dot)});const mainDiv=g.querySelector(".gallery-main");if(mainDiv)mainDiv.addEventListener("click",()=>{galleryIdx=0;lb?.classList.remove("hidden");document.body.style.overflow="hidden"});lb?.addEventListener("click",e=>{if(e.target===lb||e.target.classList.contains("gallery-lb-container")){lb.classList.add("hidden");document.body.style.overflow=""}})});document.addEventListener("keydown",e=>{const lb=document.querySelector(".gallery-lightbox");if(!lb||lb.classList.contains("hidden"))return;if(e.key==="Escape"){lb.classList.add("hidden");document.body.style.overflow=""}if(e.key==="ArrowLeft")galleryNav(-1);if(e.key==="ArrowRight")galleryNav(1)})});
</script>
</body>